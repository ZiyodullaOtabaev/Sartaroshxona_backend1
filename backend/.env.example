# ═══════════════════════════════════════════════════════════
# SARTAROSHXONA BACKEND — Environment Variables
# Bu faylni .env nomi bilan copy qiling va o'z qiymatlaringizni yozing
# ═══════════════════════════════════════════════════════════

# ─── SECRET KEY (Production'da ALBATTA o'zgartiring!) ──────
SECRET_KEY=sizning-maxfiy-kalitingiz-bu-yerda-minimum-32-belgi

# ─── SERVER ────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# Bu yerga kompyuteringizning Wi-Fi IP manzilini yozing:
SERVER_BASE_URL=http://192.168.1.100:8000

# ─── DATABASE ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=0000
DB_NAME=sartaroshxona_db

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=*
